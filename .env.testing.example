# Copiar a .env.testing y ajustar (no commitear secretos).
# Playwright carga `.env` y luego `.env.testing` al ejecutar `npm run test:e2e`.
# Si en `.env` defines ENVIRONMENT=local, los tests abren el navegador visible (salvo CI).

# URL base del staffing_cliente (sin barra final recomendada; ajustar puerto a tu servidor local)
E2E_BASE_URL=http://127.0.0.1:8080

# Usuario o correo y contraseña de un usuario válido en el entorno de pruebas
E2E_USER=admin
E2E_PASSWORD=cambiar-por-contraseña-real
# el valor "local" muestra el navegador visible (salvo CI)
ENVIRONMENT=development